# Copy to backend/.env to override defaults (LLD v1.2 §12).

# Storage — both modes are durable
STORAGE=memory                       # memory | postgres
SNAPSHOT_PATH=./.gapdb.sqlite         # durable snapshot for in-memory mode
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/gapdb

# Source workbooks (relative to backend/)
V1_PATH=../v1.xlsx
V2_PATH=../v2.1.xlsx

# Gap analysis
ENABLE_OPTIONAL_GAPS=false           # toggles G5..G9
TYPE_MAP_PATH=./config/type_equivalence.yaml
MANDATORY_CONVENTION=nullable_false_is_mandatory   # CONFIRMED (D2)
G1_COVERAGE_SCOPE=any_context        # any_context | per_context
